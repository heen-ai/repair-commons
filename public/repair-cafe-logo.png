<style id='cns-slidein-inline-css'>

#cns-slidein {
    position: fixed;
    bottom: 0; left: 50%;
    transform: translateX(-50%) translateY(100%);
    z-index: 9999;
    width: 100%; max-width: 750px;
    background: #fff;
    box-shadow: 0 -2px 24px rgba(0,0,0,.15);
    border-radius: 12px 12px 0 0;
    overflow: hidden;
    visibility: hidden;
    transition: transform .45s cubic-bezier(.4,0,.2,1),
                visibility 0s linear .45s;
}
#cns-slidein.cns-open {
    transform: translateX(-50%) translateY(0);
    visibility: visible;
    transition: transform .45s cubic-bezier(.4,0,.2,1),
                visibility 0s linear 0s;
}
.cns-slidein__header {
    background: #2d2e82;
    color: #fff;
    padding: 18px 52px 18px 20px;
}
.cns-slidein__title {
    font: 900 24px/32px 'Roboto', Arial, Helvetica, sans-serif;
    display: block; margin: 0;
}
.cns-slidein__close {
    position: absolute; top: 10px; right: 10px;
    width: 36px; height: 36px;
    border: none; border-radius: 50%;
    background: rgba(255,255,255,.15);
    color: #fff; font-size: 22px;
    line-height: 36px; text-align: center;
    cursor: pointer; z-index: 10000;
    padding: 0; transition: background .2s ease;
}
.cns-slidein__close:hover,
.cns-slidein__close:focus-visible {
    background: rgba(255,255,255,.3);
    outline: 2px solid #fff;
    outline-offset: 2px;
}
.cns-slidein__body {
    padding: 20px; background: #fff;
}
#cns-slidein .gfield       { margin-top: 0 !important; }
#cns-slidein .gfield input { margin: 0 !important; }
@media (max-width: 600px) {
    #cns-slidein {
        left: 0; right: 0;
        transform: translateX(0) translateY(100%);
        width: 100%; max-width: none;
    }
    #cns-slidein.cns-open {
        transform: translateX(0) translateY(0);
    }
    .cns-slidein__title  { font-size: 20px; line-height: 28px; }
    .cns-slidein__header { padding: 14px 44px 14px 16px; }
    .cns-slidein__body   { padding: 16px; }
}

/*# sourceURL=cns-slidein-inline-css */
</style>
