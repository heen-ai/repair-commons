                <script id="cns-slidein-js">
        (function () {
            "use strict";

            /* Voorkom dubbele init */
            if (window.__cns) return;
            window.__cns = 1;

            var NAME  = "cns_dismissed";
            var DAYS  = 365;
            var DELAY = 1500;
            var FORM  = 2;
            var SSL   = true;

            /* Cookie helpers */
            function getCookie(n) {
                var m = document.cookie.match(new RegExp("(?:^|; )" + n + "=([^;]*)"));
                return m ? decodeURIComponent(m[1]) : null;
            }

            function setCookie(n, v, d) {
                var parts = [
                    n + "=" + encodeURIComponent(v),
                    "path=/",
                    "expires=" + new Date(Date.now() + d * 864e5).toUTCString(),
                    "SameSite=Lax"
                ];
                if (SSL) parts.push("Secure");
                document.cookie = parts.join("; ");
            }

            /* Element ophalen */
            var el  = document.getElementById("cns-slidein");
            var btn = el ? el.querySelector(".cns-slidein__close") : null;

            /* ★ Enige check: cookie aanwezig? Dan stoppen. ★ */
            if (!el || getCookie(NAME)) return;

            /* Toon na vertraging */
            setTimeout(function () {
                el.removeAttribute("hidden");
                void el.offsetWidth;
                el.classList.add("cns-open");
            }, DELAY);

            /* Sluit-functie */
            function close(reason) {
                if (!el.classList.contains("cns-open")) return;
                el.classList.remove("cns-open");
                setCookie(NAME, reason || "dismissed", DAYS);
                var done = false;
                function finish() { if (done) return; done = true; el.setAttribute("hidden", ""); }
                el.addEventListener("transitionend", finish, { once: true });
                setTimeout(finish, 600);
            }

            /* Sluitknop (×) */
            if (btn) btn.addEventListener("click", function () { close("dismissed"); });

            /* ESC-toets */
            document.addEventListener("keydown", function (e) {
                if (e.key === "Escape") close("dismissed");
            });

            /*
             * ✘ GEEN "klik buiten popup" listener.
             *
             *   De vorige versie had document.addEventListener("click", ...)
             *   die de popup sloot bij elke klik buiten het element. Dit
             *   conflicteert met cookie-consent banners: een klik op
             *   "Cookies accepteren" werd gezien als "buiten de popup"
             *   → popup verdween + cookie werd gezet → bezoeker zag de
             *   nieuwsbrief-popup nooit meer.
             *
             *   Sluiten kan via de × knop of ESC-toets.
             */

            /* Auto-sluiten na Gravity Forms inzending */
            if (typeof jQuery !== "undefined") {
                jQuery(document).on("gform_confirmation_loaded", function (ev, fid) {
                    if (parseInt(fid, 10) === FORM) {
                        setTimeout(function () { close("subscribed"); }, 2500);
                    }
                });
            }
        })();
        </script>
